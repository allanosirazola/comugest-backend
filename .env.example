# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
# URL pública del frontend (para construir enlaces de email)
FRONTEND_URL=http://localhost:5173

# ─── Base de datos (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://comugest:comugest@localhost:5432/comugest?schema=public

# ─── JWT ────────────────────────────────────────────────────
# Genera con: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_in_production_use_long_random_value_at_least_32_chars
JWT_REFRESH_SECRET=change_me_too_different_from_access_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Email ──────────────────────────────────────────────────
# Provider: 'console' (logs only, dev) | 'smtp' (real provider)
EMAIL_PROVIDER=console
EMAIL_FROM="Comugest <no-reply@comugest.app>"
EMAIL_VERIFICATION_EXPIRES_HOURS=24
INVITATION_EXPIRES_DAYS=7

# ─── Si EMAIL_PROVIDER=smtp, configura tu provider real ─────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# RESEND_API_KEY=re_xxxxx
